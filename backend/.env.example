PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ethioshop
JWT_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
CLIENT_URL=http://localhost:5173

# Google Sign-In (same Web client ID as VITE_GOOGLE_CLIENT_ID on the frontend)
GOOGLE_CLIENT_ID=

# Email (optional — without these, emails are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EthioShop <noreply@example.com>"
