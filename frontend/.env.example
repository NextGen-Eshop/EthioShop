# Copy this file to .env and fill in your values

# Backend API base URL — must match where the backend is running
VITE_API_URL=http://localhost:5000

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
# Without this, the "Continue with Google" button will show an error message
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
